// TestMVCC001_EdgeCases 测试边界情况
func TestMVCC001_EdgeCases(t *testing.T) {
	config := &MVCCConfig{
		TxTimeout:         5 * time.Minute,
		MaxActiveTxs:      10,
		SnapshotRetention: 10 * time.Minute,
	}
	manager := NewMVCCManager(config)

	// 测试1: 达到最大事务数限制
	t.Run("MaxTransactionsLimit", func(t *testing.T) {
		txIDs := make([]uint64, 0, 10)

		// 创建10个事务（达到上限）
		for i := 0; i < 10; i++ {
			txID, err := manager.BeginTransaction()
			assert.NoError(t, err)
			txIDs = append(txIDs, txID)
		}

		// 尝试创建第11个事务，应该失败
		_, err := manager.BeginTransaction()
		assert.Error(t, err)
		assert.Equal(t, ErrTooManyTransactions, err)

		// 清理
		for _, txID := range txIDs {
			manager.CommitTransaction(txID)
		}
	})

	// 测试2: 事务不存在
	t.Run("TransactionNotFound", func(t *testing.T) {
		_, err := manager.GetTransactionReadView(99999)
		assert.Error(t, err)
		assert.Equal(t, ErrTransactionNotFound, err)

		err = manager.CommitTransaction(99999)
		assert.Error(t, err)
		assert.Equal(t, ErrTransactionNotFound, err)
	})
}

